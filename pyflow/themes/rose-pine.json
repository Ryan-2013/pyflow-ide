{
  "$schema": "https://pyflow-ide.dev/theme-schema/v1",
  "id":          "rose-pine",
  "name":        "Rosé Pine",
  "description": "All natural pine, faux fur and a bit of soho vibes for the classy minimalist",
  "author":      "rose-pine.com",
  "version":     "1.0.0",
  "type":        "dark",
  "preview":     "🌹",

  "colors": {
    "bg":   "#191724",
    "bg2":  "#1f1d2e",
    "bg3":  "#26233a",
    "bg4":  "#2a2742",
    "bg5":  "#312e44",
    "bd":   "#26233a",
    "bd2":  "#312e44",
    "bd3":  "#6e6a86",
    "tx":   "#e0def4",
    "tx2":  "#6e6a86",
    "tx3":  "#f7f3f0",
    "tx4":  "#403d52",
    "acc":  "#c4a7e7",
    "acc2": "#9b7dd3",
    "acc3": "#d4b9f9",
    "sel":  "#2a273f",
    "ya":   "#f6c177"
  },

  "nodes": {
    "import":       { "bg": "#1f2a3a", "text": "#9ccfd8", "header": "#1f2a3a" },
    "assign":       { "bg": "#1e2d2a", "text": "#31748f", "header": "#1e2d2a" },
    "call":         { "bg": "#2a1e3a", "text": "#c4a7e7", "header": "#2a1e3a" },
    "goroutine":    { "bg": "#1e2e1e", "text": "#9ccfd8", "header": "#1e2e1e" },
    "channel":      { "bg": "#1a2e2e", "text": "#31748f", "header": "#1a2e2e" },
    "match":        { "bg": "#2e2a1e", "text": "#f6c177", "header": "#2e2a1e" },
    "condition":    { "bg": "#2e2a1e", "text": "#f6c177", "header": "#2e2a1e" },
    "loop":         { "bg": "#1e2a2e", "text": "#9ccfd8", "header": "#1e2a2e" },
    "context":      { "bg": "#2a2a1a", "text": "#ebbcba", "header": "#2a2a1a" },
    "exception":    { "bg": "#2e1a1a", "text": "#eb6f92", "header": "#2e1a1a" },
    "flow_ctrl":    { "bg": "#2a1e2e", "text": "#c4a7e7", "header": "#2a1e2e" },
    "function":     { "bg": "#1e2a2e", "text": "#9ccfd8", "header": "#1e2a2e" },
    "class":        { "bg": "#2a1e2e", "text": "#ebbcba", "header": "#2a1e2e" },
    "unsafe_block": { "bg": "#2e1a1a", "text": "#eb6f92", "header": "#2e1a1a" },
    "error_check":  { "bg": "#2e2018", "text": "#f6c177", "header": "#2e2018" },
    "defer":        { "bg": "#1e1e2e", "text": "#c4a7e7", "header": "#1e1e2e" },
    "select":       { "bg": "#2e2018", "text": "#f6c177", "header": "#2e2018" },
    "other":        { "bg": "#1f1d2e", "text": "#403d52", "header": "#1f1d2e" }
  },

  "editor": {
    "base": "vs-dark",
    "inherit": true,
    "rules": [
      { "token": "",           "foreground": "e0def4", "background": "191724" },
      { "token": "comment",    "foreground": "6e6a86", "fontStyle": "italic" },
      { "token": "string",     "foreground": "f6c177" },
      { "token": "number",     "foreground": "eb6f92" },
      { "token": "keyword",    "foreground": "31748f", "fontStyle": "bold" },
      { "token": "type",       "foreground": "ebbcba" },
      { "token": "class",      "foreground": "ebbcba" },
      { "token": "function",   "foreground": "9ccfd8" },
      { "token": "variable",   "foreground": "e0def4" },
      { "token": "operator",   "foreground": "6e6a86" },
      { "token": "delimiter",  "foreground": "403d52" }
    ],
    "colors": {
      "editor.background":                    "#191724",
      "editor.foreground":                    "#e0def4",
      "editorLineNumber.foreground":          "#403d52",
      "editorLineNumber.activeForeground":    "#f6c177",
      "editor.lineHighlightBackground":       "#1f1d2e",
      "editor.selectionBackground":           "#2a273f",
      "editor.inactiveSelectionBackground":   "#211f30",
      "editorCursor.foreground":              "#c4a7e7",
      "editorBracketMatch.background":        "#2a273f",
      "editorBracketMatch.border":            "#c4a7e7",
      "editor.findMatchBackground":           "#2a273f",
      "editor.findMatchHighlightBackground":  "#211f30",
      "editorWidget.background":              "#1f1d2e",
      "editorWidget.border":                  "#26233a",
      "editorSuggestWidget.background":       "#1f1d2e",
      "editorSuggestWidget.border":           "#26233a",
      "editorSuggestWidget.selectedBackground": "#2a273f",
      "editorSuggestWidget.selectedForeground": "#c4a7e7",
      "editorSuggestWidget.highlightForeground": "#f6c177",
      "editorHoverWidget.background":         "#1f1d2e",
      "editorHoverWidget.border":             "#26233a",
      "focusBorder":                          "#c4a7e7",
      "list.hoverBackground":                 "#2a273f",
      "list.activeSelectionBackground":       "#2a273f",
      "list.activeSelectionForeground":       "#c4a7e7",
      "minimap.background":                   "#191724"
    }
  },

  "terminal": {
    "background":         "#191724",
    "foreground":         "#e0def4",
    "cursor":             "#c4a7e7",
    "cursorAccent":       "#191724",
    "selectionBackground": "#2a273f",
    "black":         "#26233a",
    "red":           "#eb6f92",
    "green":         "#31748f",
    "yellow":        "#f6c177",
    "blue":          "#9ccfd8",
    "magenta":       "#c4a7e7",
    "cyan":          "#ebbcba",
    "white":         "#e0def4",
    "brightBlack":   "#6e6a86",
    "brightRed":     "#eb6f92",
    "brightGreen":   "#31748f",
    "brightYellow":  "#f6c177",
    "brightBlue":    "#9ccfd8",
    "brightMagenta": "#c4a7e7",
    "brightCyan":    "#ebbcba",
    "brightWhite":   "#e0def4"
  }
}
