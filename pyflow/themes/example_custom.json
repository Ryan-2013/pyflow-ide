{
  "$schema": "https://pyflow-ide.dev/theme-schema/v1",
  "id":          "my-theme",
  "name":        "我的主題",
  "description": "主題說明",
  "author":      "作者",
  "version":     "1.0.0",
  "type":        "dark",
  "preview":     "🎨",

  "_usage": "把此檔案複製並重新命名，修改顏色後放回 themes/ 目錄。執行 python tools/build_theme.py themes/my-theme.json --apply 套用。",

  "colors": {
    "_note": "所有值必須是 6 位十六進制色碼（#RRGGBB）",

    "bg":   "#?????? 主背景",
    "bg2":  "#?????? 第二層（面板）",
    "bg3":  "#?????? 第三層（卡片）",
    "bg4":  "#?????? 懸停狀態",
    "bg5":  "#?????? 點選狀態",

    "bd":   "#?????? 主邊框",
    "bd2":  "#?????? 次邊框",
    "bd3":  "#?????? 強邊框",

    "tx":   "#?????? 主要文字",
    "tx2":  "#?????? 次要文字",
    "tx3":  "#?????? 強調文字",
    "tx4":  "#?????? 弱化文字",

    "acc":  "#?????? 強調色",
    "acc2": "#?????? 深強調色",
    "acc3": "#?????? 淺強調色",
    "sel":  "#?????? 選中背景",
    "ya":   "#?????? 高亮黃色"
  },

  "nodes": {
    "_note": "bg=節點背景色, text=主標籤文字色, header=頂部色條(可與bg相同)",
    "import":       { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "assign":       { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "call":         { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "goroutine":    { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "channel":      { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "match":        { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "condition":    { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "loop":         { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "context":      { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "exception":    { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "flow_ctrl":    { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "function":     { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "class":        { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "unsafe_block": { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "error_check":  { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "defer":        { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "select":       { "bg": "#??????", "text": "#??????", "header": "#??????" },
    "other":        { "bg": "#??????", "text": "#??????", "header": "#??????" }
  },

  "editor": {
    "_note": "base 選 vs 或 vs-dark，inherit:true 只覆蓋定義的部分",
    "base": "vs-dark",
    "inherit": true,
    "rules": [
      { "token": "",          "foreground": "??????" },
      { "token": "comment",   "foreground": "??????", "fontStyle": "italic" },
      { "token": "string",    "foreground": "??????" },
      { "token": "number",    "foreground": "??????" },
      { "token": "keyword",   "foreground": "??????", "fontStyle": "bold" },
      { "token": "type",      "foreground": "??????" },
      { "token": "function",  "foreground": "??????" },
      { "token": "variable",  "foreground": "??????" },
      { "token": "operator",  "foreground": "??????" }
    ],
    "colors": {
      "editor.background":                    "#??????",
      "editor.foreground":                    "#??????",
      "editorCursor.foreground":              "#??????",
      "editor.selectionBackground":           "#??????",
      "editor.lineHighlightBackground":       "#??????",
      "editorLineNumber.foreground":          "#??????",
      "editorLineNumber.activeForeground":    "#??????",
      "editorWidget.background":              "#??????",
      "editorWidget.border":                  "#??????",
      "editorSuggestWidget.selectedBackground": "#??????",
      "editorSuggestWidget.highlightForeground": "#??????",
      "editorHoverWidget.background":         "#??????",
      "focusBorder":                          "#??????",
      "list.activeSelectionBackground":       "#??????",
      "list.activeSelectionForeground":       "#??????"
    }
  },

  "terminal": {
    "background":         "#??????",
    "foreground":         "#??????",
    "cursor":             "#??????",
    "cursorAccent":       "#??????",
    "selectionBackground": "#??????",
    "black":   "#??????", "red":     "#??????", "green":   "#??????", "yellow": "#??????",
    "blue":    "#??????", "magenta": "#??????", "cyan":    "#??????", "white":  "#??????",
    "brightBlack":   "#??????", "brightRed":     "#??????",
    "brightGreen":   "#??????", "brightYellow":  "#??????",
    "brightBlue":    "#??????", "brightMagenta": "#??????",
    "brightCyan":    "#??????", "brightWhite":   "#??????"
  }
}
